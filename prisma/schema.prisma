// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id            String   @id @default(uuid())
  name          String
  phone         String
  city          String
  qualification String
  interest      String
  created_at    DateTime @default(now())

  @@map("leads")
}
